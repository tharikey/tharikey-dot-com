{
  "name": "tharikey-dot-com",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "sync:docs": "node scripts/sync-docs.mjs",
    "fetch:release": "node scripts/fetch-release.mjs",
    "wasm": "wasm-pack build ../tharikey-engine/bindings/wasm --dev --target web --out-dir \"$PWD/public/wasm\" --out-name tharikey",
    "ci:build": "node scripts/sync-docs.mjs && node scripts/fetch-release.mjs && astro build"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.39.3",
    "astro": "^6.4.4"
  }
}