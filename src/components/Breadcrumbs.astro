---
// Breadcrumb trail, derived from the current URL path. Each segment links to its level except the
// last (the current page). Pass `current` to override the last crumb's label for dynamic routes
// (e.g. a news post, where the slug isn't a nice title).
interface Props {
  current?: string;
}
const { current } = Astro.props;

// Nice labels for known segments; anything else is title-cased from the slug.
const LABELS: Record<string, string> = {
  download: 'Download',
  fonts: 'Fonts',
  guides: 'Guides',
  news: 'News',
  about: 'About',
  sponsors: 'Sponsors',
};
const titleCase = (s: string) =>
  s.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());

const segments = Astro.url.pathname.split('/').filter(Boolean);
const crumbs = [
  { label: 'Home', href: '/' },
  ...segments.map((seg, i) => ({
    label: LABELS[seg] ?? titleCase(seg),
    href: '/' + segments.slice(0, i + 1).join('/') + '/',
  })),
];
if (current && crumbs.length > 1) crumbs[crumbs.length - 1].label = current;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {crumbs.map((c, i) => (
      <li>
        {i < crumbs.length - 1 ? (
          <>
            <a href={c.href}>{c.label}</a>
            <span class="sep" aria-hidden="true">/</span>
          </>
        ) : (
          <span aria-current="page">{c.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    margin-bottom: 0.85rem;
  }
  .breadcrumbs ol {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    font-size: 0.85rem;
  }
  .breadcrumbs li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .breadcrumbs a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .breadcrumbs a:hover {
    color: var(--color-accent);
  }
  .breadcrumbs [aria-current='page'] {
    color: var(--color-accent);
    font-weight: 600;
  }
  .sep {
    color: var(--color-border);
  }
</style>
