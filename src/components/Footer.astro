---
// Full sitemap + credits, per the IA footer brief. Curated columns (not the top nav),
// a brand block, and a bottom bar. Colour/type from the shared tokens.
import { site, release } from '../config/site';

const cols = [
  {
    heading: 'Product',
    links: [
      { href: '/download/', label: 'Download' },
      { href: '/guides/', label: 'Guides' },
      { href: '/#playground', label: 'Playground' },
      { href: '/fonts/', label: 'Fonts' },
    ],
  },
  {
    heading: 'Developers',
    links: [
      { href: '/docs/', label: 'Documentation' },
      { href: site.github, label: 'GitHub', external: true },
    ],
  },
  {
    heading: 'Project',
    links: [
      { href: '/about/', label: 'About' },
      { href: '/about/#sponsors', label: 'Sponsors' },
      { href: '/news/', label: 'News' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="inner">
    <div class="brand">
      <a href="/" class="wordmark">ThariKey</a>
      <p class="tagline">Bringing sanity to Thaana input across the board.</p>
      <a class="gh" href={site.github} aria-label="ThariKey on GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.42.36.8 1.08.8 2.18v3.23c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"
          />
        </svg>
      </a>
    </div>

    <nav class="cols" aria-label="Footer">
      {cols.map((c) => (
        <div class="col">
          <h4>{c.heading}</h4>
          <ul>
            {c.links.map((l) => (
              <li>
                <a href={l.href} {...(l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>

  <div class="bar">
    <p>© {year} ThariKey{release.version ? ` · v${release.version}` : ''} · Open source</p>
    <p class="made">Made with care in the Maldives</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 5rem;
    background: var(--color-surface-subtle);
    border-top: 1px solid var(--color-border);
  }
  .inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2.5rem;
    display: grid;
    grid-template-columns: 1.4fr 2fr;
    gap: 3rem;
  }

  /* brand block */
  .wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--color-accent);
    text-decoration: none;
  }
  .tagline {
    margin: 0.75rem 0 1.25rem;
    color: var(--color-text-muted);
    max-width: 22rem;
  }
  .gh {
    display: inline-flex;
    color: var(--color-text-muted);
    transition: color 0.18s, transform 0.18s;
  }
  .gh:hover {
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  /* link columns */
  .cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  h4 {
    margin: 0 0 0.9rem;
    font-size: 0.74rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  li {
    margin: 0.5rem 0;
  }
  .col a {
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.15s;
  }
  .col a:hover {
    color: var(--color-accent);
  }

  /* bottom bar */
  .bar {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 1.25rem 1.5rem 2rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .bar p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  @media (max-width: 52rem) {
    .inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
  @media (max-width: 34rem) {
    .cols {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
