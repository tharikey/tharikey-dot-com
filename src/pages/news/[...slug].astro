---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news', (p) => !p.data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={post.data.title} description={post.data.summary}>
  <article class="post">
    <Breadcrumbs current={post.data.title} />
    <time datetime={post.data.date.toISOString()}>{fmtDate(post.data.date)}</time>
    <h1>{post.data.title}</h1>
    <div class="body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post { max-width: 44rem; margin: 0 auto; padding-top: 1.5rem; }
  .back { color: var(--color-accent); text-decoration: none; font-weight: 600; font-size: 0.9rem; }
  time { display: block; color: var(--color-text-muted); margin: 1.5rem 0 0.4rem; font-size: 0.9rem; }
  h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 2rem;
  }
  .body { font-size: 1.12rem; line-height: 1.75; }
  .body :global(p) { margin: 0 0 1.25rem; }
  .body :global(a) { color: var(--color-accent); }
  .body :global(h2) { font-family: var(--font-display); font-weight: 600; margin: 2rem 0 0.75rem; }
</style>
