---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', (p) => !p.data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="News" description="Milestones and updates from the ThariKey project.">
  <PageHeader
    title="Updates & milestones"
    intro="Notes from the project as the pieces land."
  />

  <ul class="posts">
    {posts.map((p) => (
      <li>
        <a href={`/news/${p.id}/`}>
          <time datetime={p.data.date.toISOString()}>{fmtDate(p.data.date)}</time>
          <h2>{p.data.title}</h2>
          <p>{p.data.summary}</p>
          <span class="read">Read →</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .posts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }
  .posts a {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    text-decoration: none;
    transition: transform 0.18s, box-shadow 0.18s;
  }
  .posts a:hover { transform: translateY(-2px); box-shadow: var(--shadow-card); }
  .posts time { color: var(--color-text-muted); font-size: 0.84rem; }
  .posts h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    margin: 0.4rem 0 0.5rem;
  }
  .posts p { color: var(--color-text-muted); margin: 0 0 0.85rem; }
  .read { color: var(--color-accent); font-weight: 600; font-size: 0.9rem; }
</style>
